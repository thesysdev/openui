root=St([St([Text("Pricing","large-heavy"),Text("Choose the plan that fits your team today. Upgrade, downgrade, or cancel anytime.","default"),TagB(["Monthly billing","Annual discounts available","No hidden fees"])],"column","s"),St([Ca([CardH("Basic","For individuals and small projects"),Text("$12 / month","large-heavy"),Text("Core features to get started with reliable essentials.","default"),Text("Includes:","small-heavy"),M("- 1 workspace\n- Up to 3 projects\n- 5 GB storage\n- Community support\n- Basic analytics","clear"),Bu([B("Start Basic","action:select_plan_basic","secondary"),B("Try free","action:trial_basic","tertiary")])],"card"),Ca([CardH("Pro","For growing teams that need more power"),Text("$29 / month","large-heavy"),Text("Advanced collaboration, automation, and deeper insights.","default"),Text("Everything in Basic, plus:","small-heavy"),M("- 5 workspaces\n- Unlimited projects\n- 100 GB storage\n- Team roles & permissions\n- Automations (1,000 runs/month)\n- Integrations (Slack, GitHub, Zapier)\n- Priority email support","clear"),Bu([B("Choose Pro","action:select_plan_pro","primary"),B("Try free","action:trial_pro","secondary")]),Cal("success","Most popular","Best value for teams that want to scale without switching tools later.")],"sunk"),Ca([CardH("Enterprise","For organizations with advanced security and scale"),Text("Custom pricing","large-heavy"),Text("Security, compliance, and dedicated support tailored to your needs.","default"),Text("Everything in Pro, plus:","small-heavy"),M("- Unlimited workspaces\n- Unlimited storage (fair use)\n- SSO/SAML & SCIM provisioning\n- Audit logs & data retention controls\n- Dedicated success manager\n- 99.9% uptime SLA\n- Custom legal & invoicing","clear"),Bu([B("Contact sales","action:contact_sales_enterprise","primary"),B("Request demo","action:request_demo_enterprise","secondary")]),Tex("neutral","Need procurement support?","We can provide security docs, vendor onboarding, and custom terms.")],"card")],"row","l","stretch","start",true),Text("Feature comparison","large-heavy"),Tab([C("Feature","string"),C("Basic","string"),C("Pro","string"),C("Enterprise","string")],[["Price (monthly)","$12","$29","Custom"],["Workspaces","1","5","Unlimited"],["Projects","Up to 3","Unlimited","Unlimited"],["Storage","5 GB","100 GB","Unlimited (fair use)"],["Team members","1","Up to 25","Unlimited"],["Roles & permissions","—","Yes","Advanced (custom roles)"],["Automations","—","1,000 runs/mo","Unlimited (policy-based)"],["Integrations","Limited","Standard","Standard + custom"],["Analytics","Basic","Advanced","Advanced + exports"],["SSO (SAML)","—","—","Yes"],["SCIM provisioning","—","—","Yes"],["Audit logs","—","—","Yes"],["Support","Community","Priority email","Dedicated + SLA"]]),A([Ac("billing","Can I switch plans later?",[Text("Yes. You can upgrade or downgrade at any time. Changes take effect immediately, and we prorate when applicable.")]),Ac("trial","Do you offer a free trial?",[Text("Yes. Basic and Pro include a free trial. Enterprise trials are available upon request via Sales.")]),Ac("annual","Do you offer annual billing?",[Text("Yes. Annual billing includes a discount. Contact Sales for Enterprise annual terms and invoicing.")]),Ac("security","What about security and compliance?",[Text("Enterprise includes SSO/SAML, SCIM, audit logs, and data retention controls. We can share security documentation during procurement.")])])],"column","xl")
