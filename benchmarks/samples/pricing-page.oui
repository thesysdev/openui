root=Sta([Sta([Te("Pricing","large-heavy"),Te("Choose the plan that fits your team today. Upgrade, downgrade, or cancel anytime.","default"),TB(["Monthly billing","Annual discounts available","No hidden fees"])],"column","s"),Sta([Car([CH("Basic","For individuals and small projects"),Te("$12 / month","large-heavy"),Te("Core features to get started with reliable essentials.","default"),Te("Includes:","small-heavy"),MDR("- 1 workspace\n- Up to 3 projects\n- 5 GB storage\n- Community support\n- Basic analytics","clear"),B([Bu("Start Basic","action:select_plan_basic","secondary"),Bu("Try free","action:trial_basic","tertiary")])],"card"),Car([CH("Pro","For growing teams that need more power"),Te("$29 / month","large-heavy"),Te("Advanced collaboration, automation, and deeper insights.","default"),Te("Everything in Basic, plus:","small-heavy"),MDR("- 5 workspaces\n- Unlimited projects\n- 100 GB storage\n- Team roles & permissions\n- Automations (1,000 runs/month)\n- Integrations (Slack, GitHub, Zapier)\n- Priority email support","clear"),B([Bu("Choose Pro","action:select_plan_pro","primary"),Bu("Try free","action:trial_pro","secondary")]),Ca("success","Most popular","Best value for teams that want to scale without switching tools later.")],"sunk"),Car([CH("Enterprise","For organizations with advanced security and scale"),Te("Custom pricing","large-heavy"),Te("Security, compliance, and dedicated support tailored to your needs.","default"),Te("Everything in Pro, plus:","small-heavy"),MDR("- Unlimited workspaces\n- Unlimited storage (fair use)\n- SSO/SAML & SCIM provisioning\n- Audit logs & data retention controls\n- Dedicated success manager\n- 99.9% uptime SLA\n- Custom legal & invoicing","clear"),B([Bu("Contact sales","action:contact_sales_enterprise","primary"),Bu("Request demo","action:request_demo_enterprise","secondary")]),T("neutral","Need procurement support?","We can provide security docs, vendor onboarding, and custom terms.")],"card")],"row","l","stretch","start",