root=S([S([T("Pricing","large-heavy"),T("Choose the plan that fits your team today. Upgrade, downgrade, or cancel anytime.","default"),TB(["Monthly billing","Annual discounts available","No hidden fees"])],"column","s"),S([C([H("Basic","For individuals and small projects"),T("$12 / month","large-heavy"),T("Core features to get started with reliable essentials.","default"),T("Includes:","small-heavy"),MDR("- 1 workspace\n- Up to 3 projects\n- 5 GB storage\n- Community support\n- Basic analytics","clear"),Bu([B("Start Basic","action:select_plan_basic","secondary"),B("Try free","action:trial_basic","tertiary")])],"card"),C([H("Pro","For growing teams that need more power"),T("$29 / month","large-heavy"),T("Advanced collaboration, automation, and deeper insights.","default"),T("Everything in Basic, plus:","small-heavy"),MDR("- 5 workspaces\n- Unlimited projects\n- 100 GB storage\n- Team roles & permissions\n- Automations (1,000 runs/month)\n- Integrations (Slack, GitHub, Zapier)\n- Priority email support","clear"),Bu([B("Choose Pro","action:select_plan_pro","primary"),B("Try free","action:trial_pro","secondary")]),Cal("success","Most popular","Best value for teams that want to scale without switching tools later.")],"sunk"),C([H("Enterprise","For organizations with advanced security and scale"),T("Custom pricing","large-heavy"),T("Security, compliance, and dedicated support tailored to your needs.","default"),T("Everything in Pro, plus:","small-heavy"),MDR("- Unlimited workspaces\n- Unlimited storage (fair use)\n- SSO/SAML & SCIM provisioning\n- Audit logs & data retention controls\n- Dedicated success manager\n- 99.9% uptime SLA\n- Custom legal & invoicing","clear"),Bu([B("Contact sales","action:contact_sales_enterprise","primary"),B("Request demo","action:request_demo_enterprise","secondary")]),Te("neutral","Need procurement support?","We can provide security docs, vendor onboarding, and custom terms.")],"card")],"row","l","stretch","start",true),T("Feature comparison","large-heavy"),Ta([L("Feature","string"),L("Basic","string"),L("Pro","string"),L("Enterprise","string")],[["Price (monthly)","$12","$29","Custom"],["Workspaces","1","5","Unlimited"],["Projects","Up to 3","Unlimited","Unlimited"],["Storage","5 GB","100 GB","Unlimited (fair use)"],["Team members","1","Up to 25","Unlimited"],["Roles & permissions","—","Yes","Advanced (custom roles)"],["Automations","—","1,000 runs/mo","Unlimited (policy-based)"],["Integrations","Limited","Standard","Standard + custom"],["Analytics","Basic","Advanced","Advanced + exports"],["SSO (SAML)","—","—","Yes"],["SCIM provisioning","—","—","Yes"],["Audit logs","—","—","Yes"],["Support","Community","Priority email","Dedicated + SLA"]]),A([AI("billing","Can I switch plans later?",[T("Yes. You can upgrade or downgrade at any time. Changes take effect immediately, and we prorate when applicable.")]),AI("trial","Do you offer a free trial?",[T("Yes. Basic and Pro include a free trial. Enterprise trials are available upon request via Sales.")]),AI("annual","Do you offer annual billing?",[T("Yes. Annual billing includes a discount. Contact Sales for Enterprise annual terms and invoicing.")]),AI("security","What about security and compliance?",[T("Enterprise includes SSO/SAML, SCIM, audit logs, and data retention controls. We can share security documentation during procurement.")])])],"column","xl")
