root=Stack([TextContent("User Settings","large-heavy"),Tabs([TabItem("profile","Profile",[Card([CardHeader("Profile","Update your personal information and avatar."),Form("profile_update",[FormControl("Display name",Input("display_name","e.g., Alex Johnson","text",["required","minLength:2","maxLength:60"])),FormControl("Avatar URL",Input("avatar_url","https://example.com/avatar.png","url",["url"]))],Buttons([Button("Save changes","submit:profile_update","primary"),Button("Reset","action:reset_profile_form","secondary")]))],"card")]),TabItem("security","Security",[Card([CardHeader("Security","Manage sign-in protection and account security."),SwitchGroup([SwitchItem("Two-factor authentication (2FA)","Require a verification code when signing in.","two_fa","enabled",false,true,false)],"sunk"),TextCallout("info","Tip","After enabling 2FA, you may be asked to set up an authenticator app or backup codes.")],"card")]),TabItem("notifications","Notifications",[Card([CardHeader("Notifications","Choose what you want to be notified about."),SwitchGroup([SwitchItem("Email notifications","Receive updates and account messages by email.","notif_email","enabled",true,true,false),SwitchItem("Product updates","Get notified about new features and improvements.","notif_product","enabled",false,false,false),SwitchItem("Security alerts","Important alerts about sign-ins and security changes.","notif_security","enabled",true,true,false)],"sunk")],"card")])])],"column","l")
