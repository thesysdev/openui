{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "Card": {
      "$ref": "#/$defs/Card"
    },
    "CardHeader": {
      "$ref": "#/$defs/CardHeader"
    },
    "TextContent": {
      "$ref": "#/$defs/TextContent"
    },
    "MarkDownRenderer": {
      "$ref": "#/$defs/MarkDownRenderer"
    },
    "Callout": {
      "$ref": "#/$defs/Callout"
    },
    "TextCallout": {
      "$ref": "#/$defs/TextCallout"
    },
    "Image": {
      "$ref": "#/$defs/Image"
    },
    "ImageBlock": {
      "$ref": "#/$defs/ImageBlock"
    },
    "ImageGallery": {
      "$ref": "#/$defs/ImageGallery"
    },
    "CodeBlock": {
      "$ref": "#/$defs/CodeBlock"
    },
    "Table": {
      "$ref": "#/$defs/Table"
    },
    "Col": {
      "$ref": "#/$defs/Col"
    },
    "BarChart": {
      "$ref": "#/$defs/BarChart"
    },
    "LineChart": {
