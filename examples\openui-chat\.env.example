# Copy this file to .env.local and fill in your values.
# Never commit .env.local to version control.

# Required — your OpenAI API key (or a compatible provider key)
OPENAI_API_KEY=sk-...

# Optional — override to use a different OpenAI-compatible API endpoint
# OPENAI_BASE_URL=https://api.openai.com/v1

# Optional — model to use for generation (default: gpt-4o)
# OPENAI_MODEL=gpt-4o
